# TCG API (https://api.tcgapi.dev) — obtener key del dashboard
TCG_API_KEY=

# Turso / libSQL — base de datos remota (SQLite en la nube)
# URL:   turso db show <db> --url        (no es secreta)
# TOKEN: turso db tokens create <db>     (SECRETO — no lo commitees)
TURSO_DATABASE_URL=libsql://<tu-db>.turso.io
TURSO_AUTH_TOKEN=

# Secreto compartido para autenticar el cron de Vercel que dispara
# /api/cron/update-prices. Genera uno aleatorio (p.ej. `openssl rand -hex 32`).
CRON_SECRET=

# Login single-user (JWT stateless). Usuario y contraseña en claro aquí;
# AUTH_SECRET firma el JWT de sesión (mín. 16 chars, idealmente 32 bytes).
AUTH_USERNAME=arturo
AUTH_PASSWORD=
AUTH_SECRET=
